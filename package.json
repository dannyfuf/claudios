{
  "name": "claudios",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "claudios": "./dist/index.js"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/index.tsx --outdir=dist --target=bun && printf '#!/usr/bin/env bun\n' | cat - dist/index.js > dist/index.js.tmp && mv dist/index.js.tmp dist/index.js && chmod +x dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@opentui-ui/core": "^0.0.2",
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/react": "^0.0.2",
    "@opentui-ui/styles": "^0.0.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "effect": "^3.12.0",
    "opentui-spinner": "^0.0.6",
    "react": ">=19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": ">=19.0.0",
    "typescript": "^5.7.0"
  }
}
