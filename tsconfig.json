{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noImplicitOverride": true,

    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"],

    "baseUrl": ".",
    "paths": {
      "#sdk/*": ["./src/sdk/*"],
      "#state/*": ["./src/state/*"],
      "#ui/*": ["./src/ui/*"],
      "#commands/*": ["./src/commands/*"],
      "#config/*": ["./src/config/*"]
    }
  },
  "include": ["src/**/*"]
}
